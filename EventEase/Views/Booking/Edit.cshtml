@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Edit Booking";
    Layout = "~/Views/Shared/_LayoutAuthenticated.cshtml";
}

<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle text-azure">
                        EventEase &rsaquo;
                        <a asp-controller="Booking" asp-action="Index" class="text-azure text-decoration-none">Bookings</a>
                        &rsaquo; Edit
                    </div>
                    <h2 class="page-title fw-bold">Edit Booking</h2>
                </div>
                <div class="col-auto ms-auto">
                    <a asp-controller="Booking" asp-action="Index"
                       class="btn btn-outline-secondary d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12" />
                            <polyline points="12 19 5 12 12 5" />
                        </svg>
                        Back to Bookings
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row justify-content-center">
                <div class="col-lg-7 col-xl-6">

                    <!-- Booking identity banner -->
                    <div class="card border-0 shadow-sm mb-3"
                         style="background: linear-gradient(135deg, #e8f4fd 0%, #d0eaf9 100%);">
                        <div class="card-body py-3 px-4">
                            <div class="d-flex align-items-center gap-3">
                                <span class="avatar avatar-md rounded bg-azure text-white fw-bold">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                        <polyline points="14 2 14 8 20 8" />
                                    </svg>
                                </span>
                                <div>
                                    <div class="fw-semibold text-dark">Booking #@Model.Id.ToString("D4")</div>
                                    <div class="text-muted small">
                                        @(Model.Customer?.FullName ?? "—") &middot;
                                        @(Model.Event?.EventName ?? "—") &middot;
                                        @Model.BookingDate.ToString("dd MMM yyyy")
                                    </div>
                                </div>
                                <span class="badge bg-azure-lt text-azure ms-auto">Editing</span>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="avatar avatar-sm bg-azure-lt text-azure rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </span>
                                <h3 class="card-title mb-0 fw-semibold">Update Booking</h3>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <form asp-controller="Booking" asp-action="Edit" asp-route-id="@Model.Id"
                                  method="post" novalidate>
                                @Html.AntiForgeryToken()
                                <input asp-for="Id" type="hidden" />
                                <input type="hidden" id="venueIdHidden" name="VenueId" value="@Model.VenueId" />

                                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 py-2" role="alert"></div>

                                <!-- Customer -->
                                <div class="mb-3">
                                    <label asp-for="CustomerId" class="form-label fw-medium">
                                        Customer <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                                <circle cx="12" cy="7" r="4" />
                                            </svg>
                                        </span>
                                        <select asp-for="CustomerId" asp-items="ViewBag.CustomerId"
                                                class="form-select border-start-0">
                                            <option value="">— Select a customer —</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="CustomerId" class="text-danger small"></span>
                                </div>

                                <!-- Event -->
                                <div class="mb-3">
                                    <label asp-for="EventId" class="form-label fw-medium">
                                        Event <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                                <line x1="16" y1="2" x2="16" y2="6" />
                                                <line x1="8" y1="2" x2="8" y2="6" />
                                                <line x1="3" y1="10" x2="21" y2="10" />
                                            </svg>
                                        </span>
                                        <select asp-for="EventId" asp-items="ViewBag.EventId"
                                                class="form-select border-start-0" id="eventSelect">
                                            <option value="">— Select an event —</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="EventId" class="text-danger small"></span>
                                </div>

                                <!-- Venue — auto-filled from selected event -->
                                <div class="mb-3">
                                    <label class="form-label fw-medium">Venue</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                                <polyline points="9 22 9 12 15 12 15 22" />
                                            </svg>
                                        </span>
                                        <input type="text" id="venueDisplay"
                                               class="form-control border-start-0 bg-light"
                                               value="@(Model.Event?.Venue?.VenueName ?? Model.Venue?.VenueName ?? "")"
                                               placeholder="Auto-filled when you select an event"
                                               readonly />
                                    </div>
                                    <div class="form-text">Venue is determined by the selected event.</div>
                                </div>

                                <!-- Booking Date — auto-filled from selected event -->
                                <div class="mb-4">
                                    <label class="form-label fw-medium">Booking Date</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                                <line x1="16" y1="2" x2="16" y2="6" />
                                                <line x1="8" y1="2" x2="8" y2="6" />
                                                <line x1="3" y1="10" x2="21" y2="10" />
                                            </svg>
                                        </span>
                                        <input type="text" id="dateDisplay"
                                               class="form-control border-start-0 bg-light"
                                               value="@Model.BookingDate.ToString("dd MMM yyyy")"
                                               placeholder="Auto-filled when you select an event"
                                               readonly />
                                    </div>
                                    <div class="form-text">Date is determined by the selected event.</div>
                                </div>

                                <div class="d-flex gap-2 pt-2 border-top">
                                    <a asp-controller="Booking" asp-action="Index"
                                       class="btn btn-outline-secondary flex-fill">Cancel</a>
                                    <button type="submit"
                                            class="btn btn-azure flex-fill d-flex align-items-center justify-content-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                            <polyline points="17 21 17 13 7 13 7 21" />
                                            <polyline points="7 3 7 8 15 8" />
                                        </svg>
                                        Save Changes
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    @{
        await Html.RenderPartialAsync("_BookingEventAutoFill");
    }
}
