@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
    Layout = "~/Views/Shared/_LayoutAuthenticated.cshtml";
}

<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle text-azure">
                        EventEase &rsaquo; Management
                    </div>
                    <h2 class="page-title fw-bold">Bookings</h2>
                </div>
                <div class="col-auto ms-auto d-print-none d-flex gap-2">
                    <a href="@Url.Action("Search", "Booking")" class="btn btn-outline-azure d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                        Search
                    </a>
                    <a href="@Url.Action("Create", "Booking")" class="btn btn-azure d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19" />
                            <line x1="5" y1="12" x2="19" y2="12" />
                        </svg>
                        New Booking
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    <div class="d-flex align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round" class="me-2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                        @TempData["SuccessMessage"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                    <div class="d-flex align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round" class="me-2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        @TempData["ErrorMessage"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom d-flex align-items-center py-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="avatar avatar-sm bg-azure-lt text-azure rounded">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14 2 14 8 20 8" />
                            </svg>
                        </span>
                        <h3 class="card-title mb-0 fw-semibold">All Bookings</h3>
                        <span class="badge bg-azure-lt text-azure ms-1">@Model.Count()</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-vcenter table-hover card-table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-muted fw-semibold" style="width: 110px;">Booking ID</th>
                                <th class="text-muted fw-semibold">Customer</th>
                                <th class="text-muted fw-semibold">Event</th>
                                <th class="text-muted fw-semibold">Venue</th>
                                <th class="text-muted fw-semibold">Booking Date</th>
                                <th class="text-muted fw-semibold text-end" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5">
                                        <div class="empty">
                                            <div class="empty-icon">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                                                     class="text-muted">
                                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                                    <polyline points="14 2 14 8 20 8" />
                                                </svg>
                                            </div>
                                            <p class="empty-title">No bookings yet</p>
                                            <p class="empty-subtitle text-muted">Create your first booking to get started.</p>
                                            <div class="empty-action">
                                                <a href="@Url.Action("Create", "Booking")" class="btn btn-azure">New Booking</a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var booking in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-azure-lt text-azure fw-semibold"
                                                  style="font-size: 0.8rem; letter-spacing: 0.3px;">
                                                #@booking.Id.ToString("D4")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="avatar avatar-sm rounded-circle bg-azure-lt text-azure fw-bold"
                                                      style="font-size: 0.75rem;">
                                                    @(booking.Customer?.FullName?[0].ToString().ToUpper() ?? "?")
                                                </span>
                                                <div>
                                                    <div class="fw-medium">@(booking.Customer?.FullName ?? "—")</div>
                                                    <div class="text-muted small">@(booking.Customer?.Email ?? "")</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-medium">@(booking.Event?.EventName ?? "—")</div>
                                            <div class="text-muted small">
                                                @(booking.Event?.EventDate.ToString("dd MMM yyyy") ?? "")
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-1">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                     class="text-muted">
                                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                                    <circle cx="12" cy="10" r="3" />
                                                </svg>
                                                <span>@(booking.Venue?.VenueName ?? "—")</span>
                                            </div>
                                            @if (booking.Venue != null)
                                            {
                                                <div class="text-muted small ms-3">@booking.Venue.Location</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="fw-medium">@booking.BookingDate.ToString("dd MMM yyyy")</div>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-1">
                                                <a href="@Url.Action("Edit", "Booking", new { id = booking.Id })"
                                                   class="btn btn-sm btn-outline-azure d-flex align-items-center gap-1">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                    </svg>
                                                    Edit
                                                </a>
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                                        onclick="confirmDelete(@booking.Id)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <polyline points="3 6 5 6 21 6" />
                                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                                        <path d="M10 11v6" />
                                                        <path d="M14 11v6" />
                                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                                                    </svg>
                                                    Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal modal-blur fade" id="deleteModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-body text-center">
                <div class="d-flex justify-content-center mb-3">
                    <span class="avatar avatar-lg bg-danger-lt text-danger rounded-circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                            <path d="M10 11v6" />
                            <path d="M14 11v6" />
                            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                        </svg>
                    </span>
                </div>
                <h3 class="fw-bold mb-1">Delete Booking?</h3>
                <p class="text-muted mb-0">
                    Are you sure you want to delete booking <strong id="deleteBookingId"></strong>?
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <div class="w-100 d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary flex-fill"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <form id="deleteForm" method="post" class="flex-fill">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(bookingId) {
            document.getElementById('deleteBookingId').textContent = '#' + String(bookingId).padStart(4, '0');
            document.getElementById('deleteForm').action = '/bookings/delete/' + bookingId;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
