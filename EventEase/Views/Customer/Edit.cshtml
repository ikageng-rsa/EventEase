@model EventEase.Models.Customer

@{
    ViewData["Title"] = "Edit Customer";
    Layout = "~/Views/Shared/_LayoutAuthenticated.cshtml";
}

<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle text-azure">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round" class="me-1">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        EventEase &rsaquo; <a href="@Url.Action("Index", "Customer")" class="text-azure text-decoration-none">Customers</a> &rsaquo; Edit
                    </div>
                    <h2 class="page-title fw-bold">
                        Edit Customer
                    </h2>
                </div>
                <div class="col-auto ms-auto d-print-none">
                    <a href="@Url.Action("Index", "Customer")" class="btn btn-outline-secondary d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12" />
                            <polyline points="12 19 5 12 12 5" />
                        </svg>
                        Back to Customers
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row justify-content-center">
                <div class="col-lg-7 col-xl-6">

                    <!-- Customer identity banner -->
                    <div class="card border-0 shadow-sm mb-3" style="background: linear-gradient(135deg, #e8f4fd 0%, #d0eaf9 100%);">
                        <div class="card-body py-3 px-4">
                            <div class="d-flex align-items-center gap-3">
                                <span class="avatar avatar-md rounded-circle bg-azure text-white fw-bold fs-5">
                                    @(Model.FullName?.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "?")
                                </span>
                                <div>
                                    <div class="fw-semibold text-dark">@Model.FullName</div>
                                    <div class="text-muted small">Customer ID: #@Model.Id</div>
                                </div>
                                <span class="badge bg-azure-lt text-azure ms-auto">Editing</span>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="avatar avatar-sm bg-azure-lt text-azure rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </span>
                                <h3 class="card-title mb-0 fw-semibold">Update Details</h3>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <form asp-action="Edit" method="post" novalidate>
                                @Html.AntiForgeryToken()
                                <input asp-for="Id" type="hidden" />

                                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 py-2" role="alert"></div>

                                <div class="mb-3">
                                    <label asp-for="FullName" class="form-label fw-medium">
                                        Full Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                                <circle cx="12" cy="7" r="4" />
                                            </svg>
                                        </span>
                                        <input asp-for="FullName" class="form-control border-start-0"
                                               placeholder="e.g. Jane Smith" autocomplete="name" />
                                    </div>
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-medium">
                                        Email Address <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                                <polyline points="22,6 12,13 2,6" />
                                            </svg>
                                        </span>
                                        <input asp-for="Email" class="form-control border-start-0" type="email"
                                               placeholder="e.g. jane@example.com" autocomplete="email" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Phone" class="form-label fw-medium">
                                        Phone Number <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z" />
                                            </svg>
                                        </span>
                                        <input asp-for="Phone" class="form-control border-start-0"
                                               placeholder="e.g. +27 82 123 4567" autocomplete="tel" />
                                    </div>
                                    <span asp-validation-for="Phone" class="text-danger small"></span>
                                </div>

                                <div class="d-flex gap-2 pt-2 border-top">
                                    <a href="@Url.Action("Index", "Customer")"
                                       class="btn btn-outline-secondary flex-fill">
                                        Cancel
                                    </a>
                                    <button type="submit" class="btn btn-azure flex-fill d-flex align-items-center justify-content-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                            <polyline points="17 21 17 13 7 13 7 21" />
                                            <polyline points="7 3 7 8 15 8" />
                                        </svg>
                                        Save Changes
                                    </button>
                                </div>

                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
