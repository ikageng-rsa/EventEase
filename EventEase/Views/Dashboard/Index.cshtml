@model EventEase.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutAuthenticated.cshtml";
    var today = DateTime.Today;
}

<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle text-azure">EventEase &rsaquo; Overview</div>
                    <h2 class="page-title fw-bold">Dashboard</h2>
                </div>
                <div class="col-auto ms-auto d-flex gap-2">
                    <a asp-controller="Customer" asp-action="Create" class="btn btn-outline-azure d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Add Customer
                    </a>
                    <a asp-controller="Event" asp-action="Create" class="btn btn-outline-azure d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Add Event
                    </a>
                    <a asp-controller="Booking" asp-action="Create" class="btn btn-azure d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        New Booking
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    <div class="d-flex align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                        @TempData["SuccessMessage"]
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- ── Headline stat cards ──────────────────────────────────── -->
            <div class="row g-3 mb-3">

                <div class="col-sm-6 col-xl-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <span class="text-muted fw-semibold" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">Total Customers</span>
                                <span class="avatar avatar-sm bg-azure-lt text-azure rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                                </span>
                            </div>
                            <div class="d-flex align-items-end gap-2">
                                <div class="display-6 fw-bold text-dark lh-1">@Model.TotalCustomers</div>
                            </div>
                            <div class="mt-2">
                                <a asp-controller="Customer" asp-action="Index" class="text-azure small text-decoration-none fw-medium">View all →</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <span class="text-muted fw-semibold" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">Total Venues</span>
                                <span class="avatar avatar-sm bg-green-lt text-green rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                                </span>
                            </div>
                            <div class="display-6 fw-bold text-dark lh-1">@Model.TotalVenues</div>
                            <div class="mt-2">
                                <a asp-controller="Venue" asp-action="Index" class="text-azure small text-decoration-none fw-medium">View all →</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <span class="text-muted fw-semibold" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">Total Events</span>
                                <span class="avatar avatar-sm bg-yellow-lt text-yellow rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                                </span>
                            </div>
                            <div class="display-6 fw-bold text-dark lh-1">@Model.TotalEvents</div>
                            <div class="mt-2">
                                <span class="badge bg-yellow-lt text-yellow me-1">@Model.UpcomingEvents upcoming</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-xl-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <span class="text-muted fw-semibold" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">Total Bookings</span>
                                <span class="avatar avatar-sm bg-purple-lt text-purple rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                </span>
                            </div>
                            <div class="display-6 fw-bold text-dark lh-1">@Model.TotalBookings</div>
                            <div class="mt-2">
                                <span class="badge bg-azure-lt text-azure me-1">@Model.BookingsThisMonth this month</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── Row 2: Recent bookings + Upcoming events ────────────── -->
            <div class="row g-3 mb-3">

                <!-- Recent bookings -->
                <div class="col-lg-7">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <span class="avatar avatar-sm bg-azure-lt text-azure rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                </span>
                                <h3 class="card-title mb-0 fw-semibold">Recent Bookings</h3>
                            </div>
                            <a asp-controller="Booking" asp-action="Index" class="btn btn-sm btn-outline-azure">View all</a>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-vcenter table-hover card-table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-muted fw-semibold" style="width:90px;">ID</th>
                                        <th class="text-muted fw-semibold">Customer</th>
                                        <th class="text-muted fw-semibold">Event</th>
                                        <th class="text-muted fw-semibold">Date</th>
                                        <th class="text-muted fw-semibold">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.RecentBookings.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-muted">No bookings yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var b in Model.RecentBookings)
                                        {
                                            var isUpcoming = b.Event?.EventDate.Date >= today;
                                            <tr>
                                                <td>
                                                    <span class="badge bg-azure-lt text-azure fw-semibold">#@b.Id.ToString("D4")</span>
                                                </td>
                                                <td>
                                                    <div class="d-flex align-items-center gap-2">
                                                        <span class="avatar avatar-xs rounded-circle bg-azure-lt text-azure fw-bold" style="width:1.6rem;height:1.6rem;font-size:0.7rem;">
                                                            @(b.Customer?.FullName?[0].ToString().ToUpper() ?? "?")
                                                        </span>
                                                        <span class="fw-medium" style="font-size:0.875rem;">@(b.Customer?.FullName ?? "—")</span>
                                                    </div>
                                                </td>
                                                <td class="text-muted" style="font-size:0.875rem;">@(b.Event?.EventName ?? "—")</td>
                                                <td class="text-muted" style="font-size:0.875rem;">@b.BookingDate.ToString("dd MMM yy")</td>
                                                <td>
                                                    @if (isUpcoming)
                                                    {
                                                        <span class="badge bg-success-lt text-success">Upcoming</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary-lt text-secondary">Completed</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Upcoming events -->
                <div class="col-lg-5">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <span class="avatar avatar-sm bg-yellow-lt text-yellow rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                                </span>
                                <h3 class="card-title mb-0 fw-semibold">Upcoming Events</h3>
                            </div>
                            <a asp-controller="Event" asp-action="Index" class="btn btn-sm btn-outline-azure">View all</a>
                        </div>
                        <div class="card-body p-0">
                            @if (!Model.NextEvents.Any())
                            {
                                <div class="text-center py-4 text-muted">No upcoming events.</div>
                            }
                            else
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var ev in Model.NextEvents)
                                    {
                                        var bookingCount = Model.EventBookingCounts.GetValueOrDefault(ev.Id, 0);
                                        var capacity = ev.Venue?.Capacity ?? 1;
                                        var pct = Math.Min(100, (int)Math.Round((double)bookingCount / capacity * 100));
                                        var daysUntil = (ev.EventDate.Date - today).Days;

                                        string progressColor = pct >= 90 ? "bg-danger" : pct >= 60 ? "bg-warning" : "bg-success";
                                        string daysLabel = daysUntil == 0 ? "Today" : daysUntil == 1 ? "Tomorrow" : $"In {daysUntil} days";

                                        <li class="list-group-item px-4 py-3 border-0 border-bottom">
                                            <div class="d-flex align-items-start justify-content-between mb-1">
                                                <div>
                                                    <div class="fw-semibold" style="font-size:0.875rem;">@ev.EventName</div>
                                                    <div class="text-muted" style="font-size:0.775rem;">
                                                        @(ev.Venue?.VenueName ?? "No venue") &middot; @ev.EventDate.ToString("dd MMM yyyy")
                                                    </div>
                                                </div>
                                                <span class="badge @(daysUntil == 0 ? "bg-danger-lt text-danger" : "bg-azure-lt text-azure") flex-shrink-0 ms-2">
                                                    @daysLabel
                                                </span>
                                            </div>
                                            <div class="d-flex align-items-center gap-2 mt-2">
                                                <div class="progress flex-fill" style="height:5px;border-radius:3px;">
                                                    <div class="progress-bar @progressColor" style="width:@pct%"></div>
                                                </div>
                                                <span class="text-muted" style="font-size:0.75rem;white-space:nowrap;">
                                                    @bookingCount / @capacity
                                                </span>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── Row 3: Venue occupancy ──────────────────────────────── -->
            <div class="row g-3">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <span class="avatar avatar-sm bg-green-lt text-green rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                                </span>
                                <h3 class="card-title mb-0 fw-semibold">Venue Occupancy</h3>
                                <span class="text-muted small">— top venues by total bookings</span>
                            </div>
                            <a asp-controller="Venue" asp-action="Index" class="btn btn-sm btn-outline-azure">View all</a>
                        </div>
                        <div class="card-body">
                            @if (!Model.TopVenues.Any())
                            {
                                <div class="text-center py-3 text-muted">No venue data yet.</div>
                            }
                            else
                            {
                                <div class="row g-3">
                                    @foreach (var stat in Model.TopVenues)
                                    {
                                        var pct = stat.OccupancyPercent;
                                        string barColor = pct >= 90 ? "bg-danger" : pct >= 60 ? "bg-warning" : "bg-azure";

                                        <div class="col-md-6 col-xl-3">
                                            <div class="p-3 rounded border" style="background:#fafcff;">
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    <span class="avatar avatar-sm bg-azure-lt text-azure rounded fw-bold" style="font-size:0.7rem;">
                                                        @stat.Venue.VenueName[0].ToString().ToUpper()
                                                    </span>
                                                    <div class="flex-fill overflow-hidden">
                                                        <div class="fw-semibold text-truncate" style="font-size:0.875rem;">@stat.Venue.VenueName</div>
                                                        <div class="text-muted text-truncate" style="font-size:0.75rem;">@stat.Venue.Location</div>
                                                    </div>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="text-muted" style="font-size:0.775rem;">@stat.BookingCount bookings</span>
                                                    <span class="fw-semibold" style="font-size:0.8rem;">@pct%</span>
                                                </div>
                                                <div class="progress" style="height:6px;border-radius:3px;">
                                                    <div class="progress-bar @barColor" style="width:@pct%"></div>
                                                </div>
                                                <div class="text-muted mt-1" style="font-size:0.75rem;">
                                                    Capacity: @stat.Venue.Capacity
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
