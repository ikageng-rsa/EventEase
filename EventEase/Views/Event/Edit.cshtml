@model EventEase.Models.Event

@{
    ViewData["Title"] = "Edit Event";
    Layout = "~/Views/Shared/_LayoutAuthenticated.cshtml";
}

<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle text-azure">
                        EventEase &rsaquo;
                        <a asp-controller="Event" asp-action="Index" class="text-azure text-decoration-none">Events</a>
                        &rsaquo; Edit
                    </div>
                    <h2 class="page-title fw-bold">Edit Event</h2>
                </div>
                <div class="col-auto ms-auto">
                    <a asp-controller="Event" asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12" />
                            <polyline points="12 19 5 12 12 5" />
                        </svg>
                        Back to Events
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row justify-content-center">
                <div class="col-lg-7 col-xl-6">

                    <!-- Event identity banner -->
                    <div class="card border-0 shadow-sm mb-3"
                         style="background: linear-gradient(135deg, #e8f4fd 0%, #d0eaf9 100%);">
                        <div class="card-body py-3 px-4">
                            <div class="d-flex align-items-center gap-3">
                                <span class="avatar avatar-md rounded bg-azure text-white fw-bold fs-5">
                                    @Model.EventName[0].ToString().ToUpper()
                                </span>
                                <div>
                                    <div class="fw-semibold text-dark">@Model.EventName</div>
                                    <div class="text-muted small">
                                        @Model.EventDate.ToString("dd MMM yyyy") &middot; @(Model.Venue?.VenueName ?? "No venue assigned")
                                    </div>
                                </div>
                                <span class="badge bg-azure-lt text-azure ms-auto">Editing</span>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="avatar avatar-sm bg-azure-lt text-azure rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </span>
                                <h3 class="card-title mb-0 fw-semibold">Update Details</h3>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <form asp-controller="Event" asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                                @Html.AntiForgeryToken()
                                <input asp-for="Id" type="hidden" />

                                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 py-2" role="alert"></div>

                                <div class="mb-3">
                                    <label asp-for="EventName" class="form-label fw-medium">
                                        Event Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                                <line x1="16" y1="2" x2="16" y2="6" />
                                                <line x1="8" y1="2" x2="8" y2="6" />
                                                <line x1="3" y1="10" x2="21" y2="10" />
                                            </svg>
                                        </span>
                                        <input asp-for="EventName" class="form-control border-start-0"
                                               placeholder="e.g. Annual Tech Conference" />
                                    </div>
                                    <span asp-validation-for="EventName" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="EventDate" class="form-label fw-medium">
                                        Event Date <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                                <line x1="16" y1="2" x2="16" y2="6" />
                                                <line x1="8" y1="2" x2="8" y2="6" />
                                                <line x1="3" y1="10" x2="21" y2="10" />
                                            </svg>
                                        </span>
                                        <input asp-for="EventDate" class="form-control border-start-0" type="date" />
                                    </div>
                                    <span asp-validation-for="EventDate" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="VenueId" class="form-label fw-medium">
                                        Venue <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                                <polyline points="9 22 9 12 15 12 15 22" />
                                            </svg>
                                        </span>
                                        <select asp-for="VenueId" asp-items="ViewBag.VenueId"
                                                class="form-select border-start-0">
                                            <option value="">— Select a venue —</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="VenueId" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Description" class="form-label fw-medium">
                                        Description <span class="text-danger">*</span>
                                    </label>
                                    <textarea asp-for="Description" class="form-control" rows="4"
                                              placeholder="Provide a brief description of the event..."></textarea>
                                    <div class="d-flex justify-content-between mt-1">
                                        <span asp-validation-for="Description" class="text-danger small"></span>
                                        <span id="charCount" class="text-muted small ms-auto"></span>
                                    </div>
                                </div>

                                <div class="d-flex gap-2 pt-2 border-top">
                                    <a asp-controller="Event" asp-action="Index" class="btn btn-outline-secondary flex-fill">
                                        Cancel
                                    </a>
                                    <button type="submit" class="btn btn-azure flex-fill d-flex align-items-center justify-content-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                            <polyline points="17 21 17 13 7 13 7 21" />
                                            <polyline points="7 3 7 8 15 8" />
                                        </svg>
                                        Save Changes
                                    </button>
                                </div>

                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const textarea = document.getElementById('Description');
        const charCount = document.getElementById('charCount');

        function updateCount() {
            charCount.textContent = `${textarea.value.length} / 1000`;
            charCount.className = (1000 - textarea.value.length) < 100
                ? 'text-danger small ms-auto'
                : 'text-muted small ms-auto';
        }

        textarea.addEventListener('input', updateCount);
        updateCount();
    </script>
}
