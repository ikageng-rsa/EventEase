<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>@ViewData["Title"] — EventEase</title>

    <!-- Tabler CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/css/tabler.min.css" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --tblr-azure: #3b9ddd;
            --tblr-azure-lt: #e8f4fd;
            --tblr-azure-lt-hover: #d4ebf8;
            --sidebar-width: 260px;
            --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        body {
            font-family: var(--font-sans);
            background-color: #f0f6fc;
        }

        /* Sidebar */
        .navbar-vertical {
            width: var(--sidebar-width);
            border-right: 1px solid #e2ecf5;
            background: #fff;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid #e2ecf5;
            text-decoration: none;
        }

        .brand-logo {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, #3b9ddd 0%, #206fad 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .brand-logo svg {
                color: #fff;
            }

        .brand-text {
            font-size: 1rem;
            font-weight: 700;
            color: #1a2b3c;
            letter-spacing: -0.3px;
        }

        .brand-sub {
            font-size: 0.7rem;
            color: #8aa4be;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Nav sections */
        .nav-section-label {
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #a0baca;
            padding: 1.25rem 1.5rem 0.4rem;
        }

        .nav-item .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.5rem 1.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: #4a6580;
            border-radius: 0;
            transition: all 0.15s ease;
            border-left: 3px solid transparent;
            text-decoration: none;
        }

            .nav-item .nav-link:hover {
                color: var(--tblr-azure);
                background: var(--tblr-azure-lt);
                border-left-color: var(--tblr-azure);
            }

            .nav-item .nav-link.active {
                color: var(--tblr-azure);
                background: var(--tblr-azure-lt);
                border-left-color: var(--tblr-azure);
                font-weight: 600;
            }

        .nav-link svg {
            flex-shrink: 0;
            opacity: 0.7;
        }

        .nav-link.active svg,
        .nav-link:hover svg {
            opacity: 1;
        }

        /* Main content offset */
        .page-wrapper {
            margin-left: var(--sidebar-width);
        }

        /* Page header */
        .page-header {
            background: #fff;
            border-bottom: 1px solid #e2ecf5;
            padding: 1.25rem 0;
        }

        .page-pretitle {
            font-size: 0.75rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
        }

        .page-title {
            font-size: 1.375rem;
            font-weight: 700;
            color: #1a2b3c;
            letter-spacing: -0.3px;
            margin: 0;
        }

        /* Cards */
        .card {
            border-radius: 10px;
        }

        /* Azure theme overrides */
        .btn-azure {
            background-color: var(--tblr-azure);
            border-color: var(--tblr-azure);
            color: #fff;
            font-weight: 500;
        }

            .btn-azure:hover {
                background-color: #2e87c4;
                border-color: #2e87c4;
                color: #fff;
            }

        .btn-outline-azure {
            color: var(--tblr-azure);
            border-color: var(--tblr-azure);
            font-weight: 500;
        }

            .btn-outline-azure:hover {
                background-color: var(--tblr-azure);
                color: #fff;
            }

        .text-azure {
            color: var(--tblr-azure) !important;
        }

        .bg-azure {
            background-color: var(--tblr-azure) !important;
        }

        .bg-azure-lt {
            background-color: var(--tblr-azure-lt) !important;
        }

        .border-azure {
            border-color: var(--tblr-azure) !important;
        }

        /* Avatar */
        .avatar {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        .avatar-sm {
            width: 2rem;
            height: 2rem;
            font-size: 0.8rem;
        }

        .avatar-md {
            width: 2.5rem;
            height: 2.5rem;
            font-size: 1rem;
        }

        .avatar-lg {
            width: 3rem;
            height: 3rem;
            font-size: 1.2rem;
        }

        /* Input groups */
        .input-group-text {
            border-right: none;
        }

        .form-control {
            border-color: #d0e2f0;
        }

            .form-control:focus {
                border-color: var(--tblr-azure);
                box-shadow: 0 0 0 3px rgba(59, 157, 221, 0.15);
            }

        /* Table */
        .table-hover tbody tr:hover {
            background-color: #f7fafd;
        }

        .table th {
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            border-bottom: 1px solid #e2ecf5;
        }

        /* Empty state */
        .empty {
            text-align: center;
            padding: 2rem;
        }

        .empty-icon {
            margin-bottom: 1rem;
        }

        .empty-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #1a2b3c;
        }

        .empty-subtitle {
            font-size: 0.875rem;
        }

        .empty-action {
            margin-top: 1rem;
        }

        /* Modal */
        .modal-blur .modal-dialog {
            backdrop-filter: blur(4px);
        }

        /* Sidebar footer */
        .sidebar-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid #e2ecf5;
            margin-top: auto;
        }

        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
        }

        .sidebar-user-name {
            font-weight: 600;
            color: #1a2b3c;
        }

        .sidebar-user-role {
            font-size: 0.75rem;
            color: #8aa4be;
        }

        @@media (max-width: 991px) {
            .navbar-vertical

        {
            display: none;
        }

        .page-wrapper {
            margin-left: 0;
        }

        }
    </style>
</head>

<body class="antialiased">
    <div class="wrapper d-flex">

        <!-- Sidebar -->
        <aside class="navbar navbar-vertical navbar-expand-lg d-flex flex-column" style="height: 100vh; position: fixed; top: 0; left: 0; overflow-y: auto;">

            <!-- Brand -->
            <a href="/" class="navbar-brand p-3">
                <div class="brand-logo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                </div>
                <div>
                    <div class="brand-text">EventEase</div>
                    <div class="brand-sub">Booking Platform</div>
                </div>
            </a>

            <!-- Navigation -->
            <nav class="flex-fill pt-2 w-100">

                <div class="nav-section-label">Main</div>
                <ul class="nav flex-column">
                    <li class="nav-item pe-2">
                        <a href="@Url.Action("Index", "Dashboard")" class="nav-link rounded-end-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                <polyline points="9 22 9 12 15 12 15 22" />
                            </svg>
                            Dashboard
                        </a>
                    </li>
                </ul>

                <div class="nav-section-label">Management</div>
                <ul class="nav flex-column">
                    <li class="nav-item pe-2">
                        <a href="@Url.Action("Index", "Customer")" class="nav-link rounded-end-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                            Customers
                        </a>
                    </li>
                    <li class="nav-item pe-2">
                        <a href="@Url.Action("Index", "Venue")" class="nav-link rounded-end-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Venue" ? "active" : "")">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                <polyline points="9 22 9 12 15 12 15 22" />
                            </svg>
                            Venues
                        </a>
                    </li>
                    <li class="nav-item pe-2">
                        <a href="@Url.Action("Index", "Event")" class="nav-link rounded-end-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Event" ? "active" : "")">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
                            Events
                        </a>
                    </li>
                    <li class="nav-item pe-2">
                        <a href="@Url.Action("Index", "Booking")" class="nav-link rounded-end-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active" : "")">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14 2 14 8 20 8" />
                                <line x1="16" y1="13" x2="8" y2="13" />
                                <line x1="16" y1="17" x2="8" y2="17" />
                                <polyline points="10 9 9 9 8 9" />
                            </svg>
                            Bookings
                        </a>
                    </li>
                </ul>

            </nav>

            <!-- Sidebar footer -->
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <span class="avatar avatar-sm bg-azure text-white rounded-circle fw-bold">A</span>
                    <div class="flex-fill">
                        <div class="sidebar-user-name">@User.Identity?.Name?.Split('@')[0]</div>
                        <div class="sidebar-user-role">Booking Specialist</div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" title="Sign out"
                                style="background:none;border:none;padding:0;cursor:pointer;color:#8aa4be;"
                                onmouseover="this.style.color='#e53e3e'" onmouseout="this.style.color='#8aa4be'">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <polyline points="16 17 21 12 16 7" />
                                <line x1="21" y1="12" x2="9" y2="12" />
                            </svg>
                        </button>
                    </form>
                </div>
            </div>

        </aside>

        <!-- Page content -->
        <div class="flex-fill" style="min-height: 100vh;">
            @RenderBody()
        </div>

    </div>

    <!-- Tabler JS -->
    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/js/tabler.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
