@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Add Venue";
    Layout = "~/Views/Shared/_LayoutAuthenticated.cshtml";
}

<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="page-pretitle text-azure">
                        EventEase &rsaquo;
                        <a asp-controller="Venue" asp-action="Index" class="text-azure text-decoration-none">Venues</a>
                        &rsaquo; Add New
                    </div>
                    <h2 class="page-title fw-bold">Add New Venue</h2>
                </div>
                <div class="col-auto ms-auto">
                    <a asp-controller="Venue" asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12" />
                            <polyline points="12 19 5 12 12 5" />
                        </svg>
                        Back to Venues
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row justify-content-center">
                <div class="col-lg-7 col-xl-6">

                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="avatar avatar-sm bg-azure-lt text-azure rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                        <polyline points="9 22 9 12 15 12 15 22" />
                                    </svg>
                                </span>
                                <h3 class="card-title mb-0 fw-semibold">Venue Details</h3>
                            </div>
                        </div>

                        <div class="card-body p-4">
                                <form asp-controller="Venue" asp-action="Create" method="post"
                                      enctype="multipart/form-data" novalidate>
                                    @Html.AntiForgeryToken()

                                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 py-2" role="alert"></div>

                                    <div class="mb-3">
                                        <label asp-for="VenueName" class="form-label fw-medium">
                                            Venue Name <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                                    <polyline points="9 22 9 12 15 12 15 22" />
                                                </svg>
                                            </span>
                                            <input asp-for="VenueName" class="form-control border-start-0"
                                                   placeholder="e.g. The Grand Hall" />
                                        </div>
                                        <span asp-validation-for="VenueName" class="text-danger small"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Location" class="form-label fw-medium">
                                            Location <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                                    <circle cx="12" cy="10" r="3" />
                                                </svg>
                                            </span>
                                            <input asp-for="Location" class="form-control border-start-0"
                                                   placeholder="e.g. 123 Main Street, Johannesburg" />
                                        </div>
                                        <span asp-validation-for="Location" class="text-danger small"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Capacity" class="form-label fw-medium">
                                            Capacity <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-azure-lt border-end-0 text-azure">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                                    <circle cx="9" cy="7" r="4" />
                                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                                                </svg>
                                            </span>
                                            <input asp-for="Capacity" class="form-control border-start-0"
                                                   type="number" min="1" placeholder="e.g. 500" />
                                        </div>
                                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-medium">
                                            Venue Image <span class="text-muted fw-normal">(optional)</span>
                                        </label>
                                        <input type="file" name="imageFile" id="imageFile"
                                               class="form-control" accept="image/jpeg,image/png,image/webp,image/gif"
                                               onchange="previewVenueImage(this)" />
                                        <div class="form-text">JPEG, PNG, WebP or GIF. Max 5 MB.</div>
                                        <span class="text-danger small">@(ViewData.ModelState["imageFile"]?.Errors.FirstOrDefault()?.ErrorMessage)</span>
                                    </div>

                                    <!-- Live preview -->
                                    <div id="imagePreviewContainer" class="mb-4 d-none">
                                        <label class="form-label fw-medium">Preview</label>
                                        <div style="border-radius:8px;overflow:hidden;border:1px solid #e2ecf5;height:180px;">
                                            <img id="imagePreview" src="" alt="Preview"
                                                 style="width:100%;height:100%;object-fit:cover;" />
                                        </div>
                                    </div>

                                <div class="mb-4">
                                    <div class="form-check form-switch">
                                        <input asp-for="IsAvailable" class="form-check-input" type="checkbox" role="switch" />
                                        <label asp-for="IsAvailable" class="form-check-label fw-medium">
                                            Available for Booking
                                        </label>
                                    </div>
                                    <div class="form-text">
                                        Uncheck to mark this venue as unavailable — it will be excluded from new bookings.
                                    </div>
                                </div>

                                    <div class="d-flex gap-2 pt-2 border-top">
                                        <a asp-controller="Venue" asp-action="Index" class="btn btn-outline-secondary flex-fill">
                                            Cancel
                                        </a>
                                        <button type="submit" class="btn btn-azure flex-fill d-flex align-items-center justify-content-center gap-2">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                                <polyline points="17 21 17 13 7 13 7 21" />
                                                <polyline points="7 3 7 8 15 8" />
                                            </svg>
                                            Save Venue
                                        </button>
                                    </div>

                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
        <script>
            function previewVenueImage(input) {
                const container = document.getElementById('imagePreviewContainer');
                const preview   = document.getElementById('imagePreview');
                if (input.files && input.files[0]) {
                    const reader = new FileReader();
                    reader.onload = e => {
                        preview.src = e.target.result;
                        container.classList.remove('d-none');
                    };
                    reader.readAsDataURL(input.files[0]);
                } else {
                    container.classList.add('d-none');
                }
            }
        </script>
    }